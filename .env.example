# EngliGo environment variables
# Copy this file to .env for local development. NEVER commit .env to git.

# Server
PORT=3000
NODE_ENV=development

# Session - generate a strong random string for production
# example: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=replace-this-with-a-long-random-string

# Database location
# In production (GKE) this points to the mounted PVC, for example /data/engligo.db
DB_PATH=./engligo.db

# Set to "true" when running behind an HTTPS-terminating proxy/ingress
TRUST_PROXY=false
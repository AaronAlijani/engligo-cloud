<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof pageTitle !== 'undefined' ? pageTitle : 'Admin - Site Data' %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.5/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { padding: 20px; }
        .table-responsive { margin-top: 20px; }
        h1, h2 { margin-bottom: 20px; margin-top: 30px; }
    </style>
</head>
<body>
    <div class="container">
        <h1><%= typeof pageTitle !== 'undefined' ? pageTitle : 'Site Data Overview' %></h1>

        <h2>Contact Form Submissions</h2>
        <% if (typeof submissions !== 'undefined' && submissions.length > 0) { %>
            <div class="table-responsive">
                <table class="table table-striped table-bordered">
                    <thead class="table-dark">
                        <tr>
                            <th>ID</th>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Phone</th>
                            <th>Birthdate</th>
                            <th>Comment</th>
                            <th>Date Submitted</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% submissions.forEach(function(message) { %>
                            <tr>
                                <td><%= message.id %></td>
                                <td><%= message.name %></td>
                                <td><%= message.email %></td>
                                <td><%= message.phone %></td>
                                <td><%= message.birthdate %></td>
                                <td><pre><%= message.comment %></pre></td>
                                <td><%= new Date(message.submission_date).toLocaleString() %></td>
                            </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
        <% } else { %>
            <p class="alert alert-info">No contact submissions found.</p>
        <% } %>

        <h2>Registered Users</h2>
        <% if (typeof users !== 'undefined' && users.length > 0) { %>
            <div class="table-responsive">
                <table class="table table-striped table-bordered">
                    <thead class="table-primary"> <tr>
                            <th>User ID</th>
                            <th>Username</th>
                            <th>Email</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% users.forEach(function(user) { %>
                            <tr>
                                <td><%= user.id %></td>
                                <td><%= user.username %></td>
                                <td><%= user.email %></td>
                            </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
        <% } else { %>
            <p class="alert alert-info">No registered users found.</p>
        <% } %>

        <p class="mt-4"><a href="/" class="btn btn-secondary">Back to Homepage</a></p>
        </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.5/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
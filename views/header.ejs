<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof pageTitle !== 'undefined' ? pageTitle : 'EngliGo' %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.5/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-SgOJa3DmI69IUzQ2PVdRZhwQ+dy64/BUtbMJw1MZ8t5HZApcHrRKUc4W0kG879m7" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="icon" href="/Resources/favicon-16x16.png" type="image/x-icon">
    <link rel="stylesheet" href="/style.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Dynalight&display=swap" rel="stylesheet">
    <style>
        body { display: flex; flex-direction: column; min-height: 100vh; }
        main.form-wrapper { flex-grow: 1; display: flex; align-items: center; justify-content: center; padding-top: 20px; padding-bottom: 20px;}
        .form-container { max-width: 450px; width:100%; padding: 25px; background-color: #fff; border-radius: 8px; box-shadow: 0 4px 8px rgba(0,0,0,0.1); }
        .form-container h2 { margin-bottom: 20px; text-align: center; }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg bg-body-tertiary" style="position: sticky; top: 0; z-index: 50;">
        <div class="container-fluid">
            <img id="logo" src="/Resources/EngliGo_Logo_Trans.png" alt="Logo" class="d-inline-block align-text-top">
            <a id="engligobrand" class="navbar-brand" href="/">EngliGo</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarSupportedContent"
                aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarSupportedContent" style="margin-left: 150px; font-size: 20px;">
                <ul id="navbarMenu" class="navbar-nav me-auto mb-lg-0 gap-4">
                    <li class="nav-item">
                        <a class="nav-link active" aria-current="page" href="/">Home</a>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="/learnEnglish.html" role="button" data-bs-toggle="dropdown"
                            aria-expanded="false">
                            Learn English
                        </a>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" href="/learnEnglish.html">Learn English</a></li>
                            <li class="dropdown-submenu"> <a class="dropdown-item dropdown-toggle" href="/courses.html">Courses</a>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item" href="/preielts.html">Pre-IELTS</a></li>
                                    <li><a class="dropdown-item" href="/ielts.html">IELTS</a></li>
                                </ul>
                            </li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item" href="/learningHub.html">Learning Hub</a></li>
                            <li><a class="dropdown-item" href="/books.html">Books</a></li>
                        </ul>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/classes">Classes</a>
                    </li>
                    <% if (typeof isUserLoggedIn !== 'undefined' && isUserLoggedIn) { %>
                        <li class="nav-item">
                            <a class="nav-link" href="/my-bookings">My Bookings</a>
                        </li>
                    <% } %>
                    <li class="nav-item">
                        <a class="nav-link" href="/contactUs.html">Contact Us</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/aboutUs.html">About US</a>
                    </li>
                </ul>
                <form class="d-flex" role="search">
                    <input class="form-control me-2" type="search" placeholder="Search" aria-label="Search">
                    <button class="btn btn-outline-success" type="submit">Search</button>
                </form>
                <div class="d-flex align-items-center ms-lg-3 gap-2 " style="margin-right: 10px;">
                    <% if (typeof isUserLoggedIn !== 'undefined' && isUserLoggedIn) { %>
                        <a href="/logout" class="nav-link d-flex align-items-center me-3" aria-label="Log Out">
                            <i class="bi bi-box-arrow-right me-1" style="font-size: 1.6rem; vertical-align: middle;"></i>
                            <span style="font-weight: 500; text-transform: uppercase; font-size: 0.9rem;">Log Out</span>
                        </a>
                    <% } else { %>
                        <a href="/login" class="nav-link d-flex align-items-center me-3" aria-label="Log In">
                            <i class="bi bi-person-circle me-1" style="font-size: 1.6rem; vertical-align: middle;"></i>
                            <span style="font-weight: 500; text-transform: uppercase; font-size: 0.9rem;">Log In</span>
                        </a>
                    <% } %>
                    <a href="#" class="nav-link position-relative" aria-label="View Cart">
                        <i class="bi bi-cart3" style="font-size: 1.6rem;"></i>
                        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger"
                            style="font-size: 0.65em;">
                            0
                            <span class="visually-hidden">items in cart</span>
                        </span>
                    </a>
                </div>
            </div>
        </div>
    </nav>
</body>
</html>
